&lt;p&gt;&lt;img src="https://Selaphina.github.io/p/%E5%8E%8B%E7%BC%A9%E5%8C%85%E5%AF%86%E7%A0%81%E7%A0%B4%E8%A7%A3-ziperello/image-20251115150032549.png"
